<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xcw.picturebackend.mapper.CommentsMapper">

    <resultMap id="BaseResultMap" type="com.xcw.picturebackend.model.entity.Comments">
        <id property="commentId" column="commentId" jdbcType="BIGINT"/>
        <result property="userId" column="userId" jdbcType="BIGINT"/>
        <result property="targetId" column="targetId" jdbcType="BIGINT"/>
        <result property="targetType" column="targetType" jdbcType="TINYINT"/>
        <result property="targetUserId" column="targetUserId" jdbcType="BIGINT"/>
        <result property="content" column="content" jdbcType="LONGVARCHAR"/>
        <result property="parentCommentId" column="parentCommentId" jdbcType="BIGINT"/>
        <result property="rootCommentId" column="rootCommentId" jdbcType="BIGINT"/>
        <result property="replyToUserId" column="replyToUserId" jdbcType="BIGINT"/>
        <result property="likeCount" column="likeCount" jdbcType="BIGINT"/>
        <result property="dislikeCount" column="dislikeCount" jdbcType="BIGINT"/>
        <result property="location" column="location" jdbcType="VARCHAR"/>
        <result property="isRead" column="isRead" jdbcType="TINYINT"/>
        <result property="createTime" column="createTime" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="updateTime" jdbcType="TIMESTAMP"/>
        <result property="isDelete" column="isDelete" jdbcType="TINYINT"/>
    </resultMap>

    <select id="countChildrenByRoot" resultType="java.util.Map">
        SELECT rootCommentId AS rootCommentId, COUNT(*) AS cnt
        FROM comments
        WHERE isDelete = 0
          AND parentCommentId &gt; 0
          AND rootCommentId IN
        <foreach collection="rootCommentIds" item="rid" open="(" close=")" separator=",">
            #{rid}
        </foreach>
        GROUP BY rootCommentId
    </select>

    <!--
        每个根评论下，按 createTime ASC 取前 limit 条子回复（预览用）。
        用窗口函数 ROW_NUMBER()；MySQL 8+ 支持。
    -->
    <select id="listChildPreviewByRoot" resultMap="BaseResultMap">
        SELECT t.commentId, t.userId, t.targetId, t.targetType, t.targetUserId,
               t.content, t.parentCommentId, t.rootCommentId, t.replyToUserId,
               t.likeCount, t.dislikeCount, t.location, t.isRead,
               t.createTime, t.updateTime, t.isDelete
        FROM (
            SELECT c.*,
                   ROW_NUMBER() OVER (PARTITION BY c.rootCommentId ORDER BY c.createTime ASC) AS rn
            FROM comments c
            WHERE c.isDelete = 0
              AND c.parentCommentId &gt; 0
              AND c.rootCommentId IN
            <foreach collection="rootCommentIds" item="rid" open="(" close=")" separator=",">
                #{rid}
            </foreach>
        ) t
        WHERE t.rn &lt;= #{limit}
        ORDER BY t.rootCommentId, t.createTime ASC
    </select>

</mapper>
