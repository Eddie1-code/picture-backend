          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 预处理程序" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import java.nio.charset.StandardCharsets
import java.security.MessageDigest
import javax.crypto.Mac
import javax.crypto.spec.SecretKeySpec
import java.util.Base64
import java.util.UUID

def method = &quot;POST&quot;
def path = &quot;/api/user/login&quot;
def body = &quot;{\&quot;userAccount\&quot;:\&quot;Eddie\&quot;,\&quot;userPassword\&quot;:\&quot;12345678\&quot;}&quot;

def ts = String.valueOf((long)(System.currentTimeMillis() / 1000L))
def nonce = UUID.randomUUID().toString().replace(&quot;-&quot;, &quot;&quot;)

MessageDigest md = MessageDigest.getInstance(&quot;SHA-256&quot;)
byte[] digest = md.digest(body.getBytes(StandardCharsets.UTF_8))
def bodyHash = digest.collect { String.format(&quot;%02x&quot;, it) }.join()

def plain = method + &quot;\n&quot; + path + &quot;\n&quot; + ts + &quot;\n&quot; + nonce + &quot;\n&quot; + bodyHash

def secret = &quot;4E3LNRS1o+TwsNiw4wtBnvcnpdKvZW1iJgUVuzmLBW0temYx6BzcgipX+0fCgi3S&quot;
Mac mac = Mac.getInstance(&quot;HmacSHA256&quot;)
mac.init(new SecretKeySpec(secret.getBytes(StandardCharsets.UTF_8), &quot;HmacSHA256&quot;))
def sign = Base64.encoder.encodeToString(mac.doFinal(plain.getBytes(StandardCharsets.UTF_8)))

vars.put(&quot;X_TIMESTAMP&quot;, ts)
vars.put(&quot;X_NONCE&quot;, nonce)
vars.put(&quot;X_SIGNATURE&quot;, sign)</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
