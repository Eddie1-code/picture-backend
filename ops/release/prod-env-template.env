# Copy to your runtime env and replace all values.

MYSQL_URL=jdbc:mysql://127.0.0.1:3306/picture?useUnicode=true&characterEncoding=utf-8&serverTimezone=UTC
MYSQL_USERNAME=picture_root
MYSQL_PASSWORD=replace_me

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=replace_me
REDIS_CONNECT_TIMEOUT_MS=5000

COS_HOST=https://your-bucket.cos.ap-guangzhou.myqcloud.com
COS_SECRET_ID=replace_me
COS_SECRET_KEY=replace_me
COS_REGION=ap-guangzhou
COS_BUCKET=your-bucket
COS_CDN_DOMAIN=https://picture.xucanwei.xyz

ALIYUN_AI_API_KEY=replace_me
SIGNATURE_SECRET=replace_me
